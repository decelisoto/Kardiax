rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── User documents ──────────────────────────────────────────────────────
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      match /circle/{memberId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
        allow update: if request.auth != null
          && resource.data.email == request.auth.token.email
          && request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['inviteStatus', 'memberUid', 'acceptedAt', 'declinedAt']);
      }

      match /alerts/{alertId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
        allow update: if request.auth != null
          && request.resource.data.keys().hasOnly(request.resource.data.keys())
          && onlyUpdatingRespondedBy(request);
      }
    }

    // ── Public user profiles ─────────────────────────────────────────────────
    match /userProfiles/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // ── Live user status (heart rate, arrhythmia, BLE) ──────────────────────
    match /userStatus/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // ── Circle groups ────────────────────────────────────────────────────────
    match /groups/{groupId} {
      allow read: if request.auth != null
        && request.auth.uid in resource.data.memberUids;
      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.createdBy
        && request.auth.uid in request.resource.data.memberUids;
      allow update: if request.auth != null && (
        resource.data.createdBy == request.auth.uid
        || canJoinGroup(request)
        || canLeaveGroup(request)
      );
      allow delete: if request.auth != null
        && resource.data.createdBy == request.auth.uid;
    }

    // ── Invite code → groupId index ──────────────────────────────────────────
    match /groupInvites/{code} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // ── Invites ─────────────────────────────────────────────────────────────
    match /invites/{token} {
      allow read: if request.auth != null && (
        resource.data.fromUid == request.auth.uid ||
        resource.data.toEmail == request.auth.token.email
      );
      allow create: if request.auth != null
        && request.resource.data.fromUid == request.auth.uid;
      allow update: if request.auth != null
        && resource.data.toEmail == request.auth.token.email
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['status', 'acceptedByUid', 'acceptedAt', 'declinedAt']);
    }
  }
}

function onlyUpdatingRespondedBy(request) {
  return request.resource.data.diff(resource.data).affectedKeys()
    .hasOnly(['respondedBy']);
}

function canJoinGroup(request) {
  let uid = request.auth.uid;
  return !(uid in resource.data.memberUids)
    && uid in request.resource.data.memberUids
    && request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly(['memberUids', 'members', 'updatedAt']);
}

function canLeaveGroup(request) {
  let uid = request.auth.uid;
  return uid in resource.data.memberUids
    && !(uid in request.resource.data.memberUids)
    && request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly(['memberUids', 'members', 'updatedAt']);
}
